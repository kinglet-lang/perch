{
  "name": "kinglet-lsp-vscode",
  "displayName": "Perch",
  "description": "Kinglet language support for VS Code",
  "version": "0.1.0",
  "publisher": "kinglet-lang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kinglet-lang/kinglet-lsp"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:kinglet"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kinglet",
        "aliases": [
          "Kinglet",
          "kinglet"
        ],
        "extensions": [
          ".kl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kinglet",
        "scopeName": "source.kinglet",
        "path": "./syntaxes/kinglet.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Kinglet",
      "properties": {
        "kinglet.lspPath": {
          "type": "string",
          "default": "kinglet-lsp",
          "description": "Path to the kinglet-lsp language server binary."
        },
        "kinglet.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP traffic between VS Code and kinglet-lsp."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
