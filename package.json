{
  "name": "kinglet-lsp-vscode",
  "displayName": "Kinglet",
  "description": "Kinglet (.kl) syntax highlighting and language server",
  "version": "0.1.3",
  "publisher": "kinglet-lang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kinglet-lang/kinglet-lsp"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:kinglet",
    "onCommand:kinglet.showServerLog",
    "onCommand:kinglet.restartServer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kinglet",
        "aliases": [
          "Kinglet",
          "kinglet"
        ],
        "extensions": [
          ".kl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kinglet",
        "scopeName": "source.kinglet",
        "path": "./syntaxes/kinglet.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "kinglet.showServerLog",
        "title": "Show Language Server Log",
        "category": "Kinglet"
      },
      {
        "command": "kinglet.restartServer",
        "title": "Restart Language Server",
        "category": "Kinglet"
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        "*.kl": "kinglet"
      }
    },
    "configuration": {
      "title": "Kinglet",
      "properties": {
        "kinglet.lspPath": {
          "type": "string",
          "default": "kinglet-lsp",
          "description": "Path to the kinglet-lsp language server binary."
        },
        "kinglet.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "messages",
          "description": "Trace LSP traffic between VS Code and kinglet-lsp."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild client/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --sourcemap",
    "watch": "esbuild client/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --sourcemap --watch",
    "typecheck": "tsc -p ./ --noEmit",
    "prepackage": "npm run compile && node scripts/stage-vsix.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
