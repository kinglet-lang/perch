{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Perch)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "settings": {
        "kinglet.lspPath": "${workspaceFolder}/out/Default/kinglet-lsp.exe",
        "kinglet.trace.server": "verbose"
      }
    }
  ]
}
